#v(1em)
#pad(left: 1.5em)[
  A. $display(-frac(1, 21))$ #h(1fr) B. $display(-frac(1, 63))$ #h(1fr) C. $0$ #h(1fr) D. $display(frac(1, 7))$
]

#v(1em)

